TENANT_ID=your-tenant-id
CLIENT_ID=your-client-id
AUTH_MODE=interactive
CLIENT_SECRET=your-client-secret
CERT_PATH=/path/to/cert.pem
TOKEN_CACHE_PATH=./.graphmind_token_cache.json
SPEC_REPO_PATH=./msgraph-metadata
SPEC_REPO_URL=https://github.com/microsoftgraph/msgraph-metadata.git
SPEC_AUTO_CLONE=true
SPEC_REFRESH_SCHEDULE=daily
GRAPH_API_BASE=https://graph.microsoft.com
MCP_SERVER_NAME=graphmind
DEFAULT_API_VERSION=v1.0
GRAPHMIND_READ_ONLY=false
GRAPHMIND_REQUIRE_WRITE_CONFIRMATION=true
GRAPHMIND_MAX_PAGES=50
GRAPHMIND_AGGREGATE_SAMPLE_SIZE=10
GRAPHMIND_MAX_RESPONSE_CHARS=8000
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_K=20
STRUCTURAL_FILTER_CEILING=500
